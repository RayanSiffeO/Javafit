                <Component class="javax.swing.JTable" name="jTable3">
                  <Properties>
                    <Property name="model" type="javax.swing.table.TableModel" editor="org.netbeans.modules.form.editors2.TableModelEditor">
                      <Table columnCount="8" rowCount="4">
                        <Column editable="true" title="Nombre" type="java.lang.Object"/>
                        <Column editable="true" title="Tipo" type="java.lang.Object"/>
                        <Column editable="true" title="Categoria" type="java.lang.Object"/>
                        <Column editable="true" title="Sala" type="java.lang.Object"/>
                        <Column editable="true" title="Dia" type="java.lang.Object"/>
                        <Column editable="true" title="Horario" type="java.lang.Object"/>
